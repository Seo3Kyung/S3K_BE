<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

  <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
    <encoder>
      <pattern>
        %clr(%d{yyyy-MM-dd HH:mm:ss.SSS}){faint} %clr([%thread]){magenta} %clr(%-5level){yellow} %clr(%logger{36}){cyan} - %msg%n%ex{full}
      </pattern>
      <charset>utf8</charset>
    </encoder>
  </appender>

  <springProfile name="local">
    <root level="INFO">
      <appender-ref ref="CONSOLE"/>
    </root>
  </springProfile>

  <springProfile name="dev">
    <springProperty name="DISCORD_WEBHOOK_URL" source="dev.discord.webhook-url"/>

    <appender name="DISCORD" class="com.github.napstr.logback.DiscordAppender">
      <webhookUri>${DISCORD_WEBHOOK_URL}</webhookUri>
      <layout class="ch.qos.logback.classic.PatternLayout">
        <pattern>
          ``` LEVEL  [%-5level]%n TIME   [%d{yyyy-MM-dd HH:mm:ss}]%n TRACE  [%thread]%n CLASS  [%logger{35}]%n URL    [%replace(%msg){'\|.*',''}]%n =============== MESSAGE ===============%n %replace(%replace(%msg){'^[^|]*\|',''}){'\|[^|]*$',''}%n ================ DATA =================%n %replace(%msg){'.*\|',''}%n```
        </pattern>
      </layout>
      <username>에러 감지</username>
      <tts>false</tts>
    </appender>

    <appender name="ASYNC_DISCORD" class="ch.qos.logback.classic.AsyncAppender">
      <appender-ref ref="DISCORD"/>
      <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
        <level>ERROR</level>
      </filter>
    </appender>

    <root level="INFO">
      <appender-ref ref="CONSOLE"/>
      <appender-ref ref="ASYNC_DISCORD"/>
    </root>
  </springProfile>
</configuration>
